APP_NAME="CSM TECH LEARNING"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://formagrid.test

APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=csm_formagrid
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Media (video HLS, SCORM, copertine, certificati PDF)
MEDIA_DISK=s3
# Per S3: public = ACL public-read (può fallire se Block Public Access è attivo → usa policy sul bucket)
MEDIA_UPLOAD_VISIBILITY=public
# Su S3 con "ACL disattivate": lascia false (default). true solo se il bucket accetta ACL negli upload.
MEDIA_S3_PUT_ACL=false
# HLS (learner): manifest servito da rotta autenticata + segmenti S3 presigned (scadenza). true in prod con S3.
MEDIA_SIGNED_HLS_MANIFEST=false
# Durata validità URL segmenti (minuti). Deve coprire la visione del video (VOD); max 240.
MEDIA_SIGNED_HLS_TTL_MINUTES=90
# Redis: stesso server di CACHE_STORE; la coda usa la connessione Redis "default" (di solito database 0), la cache il DB 1.
# Avvia il worker: `php artisan queue:work` (o `queue:listen`). Con `sync` i job girano nella richiesta HTTP (solo debug).
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# predis = funziona senza estensione (dev/Laragon). phpredis = più veloce ma richiede ext-redis sullo stesso PHP di artisan e del web server.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Email ---
# log = solo debug. mailgun = API Mailgun (richiede symfony/mailgun-mailer). smtp = generico (anche smtp.mailgun.org).
MAIL_MAILER=mailgun
MAIL_FROM_ADDRESS="noreply@mg.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Mailgun (dashboard → Sending → Domains → domain + API keys “Private API key”)
# MAILGUN_DOMAIN = dominio verificato in Mailgun (es. mg.example.com), NON il dominio APP_URL.
MAILGUN_DOMAIN=mg.example.com
MAILGUN_SECRET=
# Solo hostname, senza https:// (altrimenti Symfony costruisce https://https://… e fallisce con “Could not reach the remote Mailgun server”).
# Regione USA: api.mailgun.net | Regione EU: api.eu.mailgun.net
MAILGUN_ENDPOINT=api.mailgun.net

# --- SMTP generico (alternativa a Mailgun API: MAIL_MAILER=smtp) ---
# MAIL_SCHEME=null
# MAIL_HOST=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=postmaster@mg.example.com
# MAIL_PASSWORD=
# MAIL_EHLO_DOMAIN=

# --- Object storage media (video HLS, SCORM, copertine) — vedi config/media.php ---
#
# Produzione consigliata: bucket S3 privato + CloudFront (Origin Access Control).
# AWS_URL = dominio della distribution (es. https://media.example.com o https://dxxxxx.cloudfront.net).
# Il browser carica sempre i file da QUEL dominio; la pagina può essere su qualsiasi host tenant
# (sottodominio, dominio custom, ecc.) → non devi elencare migliaia di origini per i media.
#
# CORS su CloudFront (Response headers policy o CloudFront Function in viewer-response):
#   - Per lettura pubblica HLS/SCORM: spesso si usa Access-Control-Allow-Origin: * su GET/HEAD,
#     oppure si rispecchia l’header Origin della richiesta (accettabile se gli URL non sono segreti).
#   - Elencare a mano ogni dominio tenant su S3/CloudFront non scala.
#
# Upload diretto browser → presigned PUT va ancora all’endpoint S3 (non CloudFront):
#   nel bucket S3, CORS con AllowedOrigins ["*"] per PUT/POST (senza credenziali) oppure proxy upload via Laravel.
#
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=
# Produzione + CloudFront: URL HTTPS del distribution (es. https://media.formagrid.it). Laravel
# lo usa come base per Storage::disk('s3')->url() → video HLS, SCORM URL pubblici in admin, copertine.
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Backup database giornaliero → S3 (php artisan backup:database-to-s3) ---
# Richiede mysqldump sul server (PATH o BACKUP_MYSQLDUMP_PATH). Scheduler: 02:00 UTC se abilitato.
# BACKUP_DATABASE_ENABLED=false
# Disco in config/filesystems.php (default: s3_backups = stesso account, bucket opzionale dedicato)
# BACKUP_S3_DISK=s3_backups
# Bucket dedicato ai backup (se vuoto: stesso AWS_BUCKET, prefisso sotto BACKUP_S3_PREFIX)
# AWS_BACKUP_BUCKET=
# BACKUP_S3_PREFIX=backups/database
# Retention (stesso bucket dei media): in S3 → bucket → Management → Lifecycle → add rule.
#   Scope: limit to prefix → uguale a BACKUP_S3_PREFIX (es. backups/database/).
#   Action: Expire current versions (es. dopo 30 o 90 giorni). I file sotto tenants/ restano intatti.
# BACKUP_MYSQLDUMP_PATH=mysqldump
# Timeout secondi per ogni dump (0 = illimitato)
# BACKUP_DUMP_TIMEOUT=0

VITE_APP_NAME="${APP_NAME}"

# Analytics (GA4) — richiede consenso cookie
GA4_MEASUREMENT_ID=
# Pausa (secondi) oltre la quale due eventi watch-time aprono una nuova “sessione” nel report admin (default 1800 = 30 min)
# WATCH_TIME_SESSION_GAP_SECONDS=1800
STAFF_AUDIT_LOG_RETENTION_DAYS=365

# Legal / società (per Privacy, Cookie, Termini, DPA)
# Ragione sociale e P.IVA per footer / compliance (Italia: es. P.IVA IT01234567890)
LEGAL_COMPANY_NAME="${APP_NAME}"
LEGAL_COMPANY_ADDRESS=
LEGAL_VAT=
LEGAL_EMAIL=info@formagrid.it
LEGAL_PRIVACY_EMAIL=
LEGAL_EFFECTIVE_DATE=2026-04-06
